APP_ENV=local
APP_BASE_URL=http://localhost:8080
BACKEND_API_BASE=http://localhost:8080
FRONTEND_BASE_URL=http://localhost:3000
ENABLE_SAMPLE_DATA=true
APPROVED_LANGUAGES=ko

DB_HOST=localhost
DB_PORT=5432
DB_NAME=geumcheon_data
DB_USERNAME=geumcheon
DB_PASSWORD=change-me

DATA_GO_KR_API_KEY=
SEOUL_OPEN_API_KEY=
# 행정안전부 재난안전데이터 공유플랫폼에서 별도 활용 신청 후 발급합니다.
SAFETY_DATA_API_KEY=
WIFI_RELAY_BASE_URL=http://127.0.0.1:18088
VWORLD_API_KEY=
SGIS_API_KEY=
KOSIS_API_KEY=
WORKNET_API_KEY=

ADMIN_INITIAL_LOGIN_ID=admin
ADMIN_INITIAL_PASSWORD=change-me
ADMIN_INITIAL_NAME=Initial Admin
ADMIN_INITIAL_EMAIL=

# CSV originals are stored under UPLOAD_BASE_PATH/admin-csv/{datasetKey}/{yyyyMMdd}/
UPLOAD_BASE_PATH=./uploads
MAX_UPLOAD_SIZE_MB=50
UPLOAD_PREVIEW_TTL_MINUTES=15
UPLOAD_MAX_PREVIEW_DRAFTS=5

COLLECTOR_ENABLED=false
COLLECTOR_DEFAULT_TIMEOUT_SECONDS=20
COLLECTOR_RETRY_COUNT=3
COLLECTOR_RETRY_DELAY_SECONDS=5
COLLECTOR_STORE_PAGE_SIZE=500
COLLECTOR_STORE_MAX_PAGES=200
COLLECTOR_STORE_PAGE_DELAY_MILLIS=200
COLLECTOR_SCHEDULE_ENABLED=false
COLLECTOR_CRON=0 0 4 * * *

# Loopback-only isolated WiFi relay. run-backend-db.ps1 generates the shared token at runtime.
WIFI_RELAY_HOST=127.0.0.1
WIFI_RELAY_PORT=18088
WIFI_RELAY_TIMEOUT_SECONDS=15
WIFI_RELAY_RETRY_COUNT=2
WIFI_RELAY_RETRY_DELAY_SECONDS=1
WIFI_RELAY_MIN_REFRESH_SECONDS=300
WIFI_RELAY_PAGE_SIZE=1000
WIFI_RELAY_MAX_PAGES=50
WIFI_RELAY_MIN_ROWS=1
WIFI_RELAY_MAX_ROWS=50000
WIFI_RELAY_MAX_CHANGE_RATIO=0.30
WIFI_RELAY_MIN_VALID_RATIO=0.70
WIFI_RELAY_STATE_PATH=.tmp/wifi-relay-state.json
WIFI_RELAY_SCHEDULE_ENABLED=false
WIFI_REALTIME_COLLECTION_ENABLED=false
WIFI_RELAY_CRON=0 10 * * * *
LIVING_FACILITY_RELAY_ENABLED=false

# Separate loopback-only relay for the approved five Seoul living-facility services.
# run-backend-db.ps1 generates LIVING_FACILITY_RELAY_TOKEN at runtime; do not persist it here.
LIVING_FACILITY_RELAY_BASE_URL=http://127.0.0.1:18089
LIVING_FACILITY_RELAY_HOST=127.0.0.1
LIVING_FACILITY_RELAY_PORT=18089
LIVING_FACILITY_RELAY_TIMEOUT_SECONDS=5
LIVING_FACILITY_RELAY_RETRY_COUNT=2
LIVING_FACILITY_RELAY_RETRY_DELAY_SECONDS=1
LIVING_FACILITY_RELAY_MIN_REFRESH_SECONDS=300
LIVING_FACILITY_RELAY_PAGE_SIZE=1000
LIVING_FACILITY_RELAY_MAX_PAGES=20
LIVING_FACILITY_RELAY_MIN_ROWS=1
LIVING_FACILITY_RELAY_MAX_ROWS=10000
LIVING_FACILITY_RELAY_MAX_CHANGE_RATIO=0.50
LIVING_FACILITY_RELAY_MIN_VALID_RATIO=0.60
LIVING_FACILITY_RELAY_STATE_PATH=.tmp/living-facility-relay-state.json

# AirKorea collection runs every three hours while COLLECTOR_ENABLED=true.
AIR_QUALITY_SCHEDULE_ENABLED=true
AIR_QUALITY_CRON=0 5 */3 * * *

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3100,http://127.0.0.1:3100
UPLOAD_STAGING_RETENTION_DAYS=30
