{
  "name": "geumcheon-platform-frontend",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "serve": "node serve-static.mjs",
    "check:syntax": "node tests/check-syntax.mjs",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test": "npm run check:syntax && npm run test:unit && npm run test:e2e"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "axe-core": "4.11.1",
    "vitest": "4.1.7"
  }
}
